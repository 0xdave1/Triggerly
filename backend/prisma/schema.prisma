generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReminderType {
  TIME
  LOCATION
  HABIT
  HYBRID
}

enum ReminderStatus {
  ACTIVE
  COMPLETED
  DELETED
  SNOOZED
}

enum LocationTriggerType {
  ARRIVAL
  DEPARTURE
}

enum HabitFrequencyType {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum ReminderEventType {
  CREATED
  TRIGGERED
  COMPLETED
  SNOOZED
  DISMISSED
  EDITED
  DELETED
}

enum DevicePlatform {
  IOS
  ANDROID
  WEB
}

enum DeliveryMode {
  PUSH
  VOICE
  VOICE_AND_PUSH
  SILENT
  URGENT
}

enum ActionType {
  DRAFT_EMAIL
  DRAFT_MESSAGE
  OPEN_PAYMENT_APP
  PAYMENT_REMINDER
  CALL_CONTACT
  OPEN_MAPS
  OPEN_URL
  CREATE_CALENDAR_EVENT
  GENERATE_CHECKLIST
  PREPARE_MEETING_NOTES
}

enum ActionPromptStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum ActionPromptEventType {
  CREATED
  UPDATED
  CONFIRMED
  CANCELLED
  COMPLETED
  CONTENT_GENERATED
}

enum TriggerType {
  TIME
  LOCATION_ARRIVAL
  LOCATION_DEPARTURE
  HABIT
  WEATHER
  EXCHANGE_RATE
  PRICE
  CONTACT
  TRAVEL
}

enum TriggerStatus {
  ACTIVE
  DISABLED
  COMPLETED
  DELETED
}

enum MemoryType {
  PERSON
  PLACE
  PRICE
  DEBT
  PROMISE
  PREFERENCE
  TRAVEL
  ROUTINE
  DOCUMENT
  GENERAL
}

enum MemorySource {
  MANUAL
  AI_EXTRACTED
  IMPORTED
}

enum MemoryStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum MemoryEventType {
  CREATED
  UPDATED
  ARCHIVED
  DELETED
  USED_IN_TRIGGER
}

enum LiveContextTriggerType {
  WEATHER
  EXCHANGE_RATE
  PRICE
  TRAVEL
}

enum LiveContextTriggerStatus {
  ACTIVE
  PAUSED
  TRIGGERED
  DELETED
}

enum PriceLogSource {
  MANUAL
  OCR
  AI_PARSE
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum AgentRunStatus {
  PLANNING
  WAITING_FOR_CONFIRMATION
  EXECUTING
  COMPLETED
  FAILED
  CANCELLED
}

enum ToolExecutionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum UserApprovalDecision {
  APPROVED
  REJECTED
  EDITED
}

model User {
  id              String                @id @default(cuid())
  name            String?
  email           String                @unique
  passwordHash    String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  reminders       Reminder[]
  events          ReminderEvent[]
  devices         Device[]
  privacySetting  UserPrivacySetting?
  voiceSetting    UserVoiceSetting?
  contactMemories ContactMemory[]
  actionPrompts   ActionPrompt[]
  actionPromptEvents ActionPromptEvent[]
  intentParseLogs IntentParseLog[]
  triggers        Trigger[]
  habitTriggers   HabitTrigger[]
  liveContextTriggers LiveContextTrigger[]
  priceLogs       PriceLog[]
  memories        Memory[]
  memoryEvents    MemoryEvent[]
  conversations   Conversation[]
  chatMessages    ChatMessage[]
  agentRuns       AgentRun[]
  toolExecutions  ToolExecution[]
  approvals       UserApproval[]
}

model Reminder {
  id              String            @id @default(cuid())
  userId          String
  title           String
  notes           String?
  type            ReminderType
  status          ReminderStatus    @default(ACTIVE)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  completedAt     DateTime?
  deletedAt       DateTime?
  deliveryMode    DeliveryMode      @default(PUSH)
  voiceScript     String?
  voiceEnabled    Boolean           @default(false)
  contactMemoryId String?
  actionPromptId  String?
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactMemory   ContactMemory?    @relation(fields: [contactMemoryId], references: [id], onDelete: SetNull)
  locationTrigger LocationTrigger?
  timeTrigger     TimeTrigger?
  habit           Habit?
  events          ReminderEvent[]
  actionPrompt    ActionPrompt?
  triggers        Trigger[]

  @@index([userId, status])
  @@index([userId, type])
}

model LocationTrigger {
  id              String              @id @default(cuid())
  reminderId      String              @unique
  placeName       String
  latitude        Float
  longitude       Float
  radiusMeters    Int
  triggerType     LocationTriggerType
  lastTriggeredAt DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  reminder        Reminder            @relation(fields: [reminderId], references: [id], onDelete: Cascade)
}

model TimeTrigger {
  id              String    @id @default(cuid())
  reminderId      String    @unique
  triggerDateTime DateTime
  timezone        String
  repeatRule      String?
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  reminder        Reminder  @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([triggerDateTime])
}

model Habit {
  id              String              @id @default(cuid())
  reminderId      String              @unique
  frequencyType   HabitFrequencyType
  frequencyCount  Int
  lastCompletedAt DateTime?
  nextDueAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  reminder        Reminder            @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@index([nextDueAt])
}

model Trigger {
  id                   String        @id @default(cuid())
  userId               String
  reminderId           String?
  type                 TriggerType
  status               TriggerStatus @default(ACTIVE)
  title                String?
  configuration        Json?
  requiresConfirmation Boolean       @default(true)
  confirmedAt          DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminder             Reminder?     @relation(fields: [reminderId], references: [id], onDelete: SetNull)
  habitTrigger         HabitTrigger?

  @@index([userId, type, status])
  @@index([reminderId])
}

model HabitTrigger {
  id              String              @id @default(cuid())
  userId          String
  triggerId       String?             @unique
  frequencyType   HabitFrequencyType
  frequencyCount  Int
  lastCompletedAt DateTime?
  nextDueAt       DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  trigger         Trigger?            @relation(fields: [triggerId], references: [id], onDelete: SetNull)

  @@index([userId, nextDueAt])
}

model LiveContextTrigger {
  id              String                   @id @default(cuid())
  userId          String
  type            LiveContextTriggerType
  title           String
  condition       Json
  status          LiveContextTriggerStatus @default(ACTIVE)
  lastCheckedAt   DateTime?
  lastTriggeredAt DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  user            User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, status])
  @@index([userId, createdAt])
}

model PriceLog {
  id            String         @id @default(cuid())
  userId        String
  itemName      String
  price         Float
  currency      String         @default("NGN")
  quantityLabel String?
  placeName     String?
  latitude      Float?
  longitude     Float?
  loggedAt      DateTime       @default(now())
  source        PriceLogSource @default(MANUAL)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, itemName, loggedAt])
}

model WeatherProviderCache {
  id          String   @id @default(cuid())
  locationKey String   @unique
  data        Json
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([expiresAt])
}

model ExchangeRateCache {
  id        String   @id @default(cuid())
  pair      String   @unique
  data      Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model Memory {
  id         String        @id @default(cuid())
  userId     String
  type       MemoryType
  title      String
  body       String
  entities   Json?
  source     MemorySource  @default(MANUAL)
  confidence Float?
  status     MemoryStatus  @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  archivedAt DateTime?
  deletedAt  DateTime?
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  events     MemoryEvent[]

  @@index([userId, type, status])
  @@index([userId, status])
}

model MemoryEvent {
  id        String          @id @default(cuid())
  userId    String
  memoryId  String
  eventType MemoryEventType
  metadata  Json?
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  memory    Memory          @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([memoryId, createdAt])
}

model ReminderEvent {
  id          String            @id @default(cuid())
  reminderId  String
  userId      String
  eventType   ReminderEventType
  timestamp   DateTime          @default(now())
  metadata    Json?
  reminder    Reminder          @relation(fields: [reminderId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp])
  @@index([reminderId, timestamp])
}

model Device {
  id          String          @id @default(cuid())
  userId      String
  platform    DevicePlatform
  pushToken   String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lastSeenAt  DateTime?
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, pushToken])
  @@index([userId])
}

model UserPrivacySetting {
  id                              String    @id @default(cuid())
  userId                          String    @unique
  locationEnabled                 Boolean   @default(false)
  voiceInputEnabled               Boolean   @default(false)
  aiParsingEnabled                Boolean   @default(true)
  dataRetentionDays               Int?
  locationTriggersEnabled         Boolean   @default(false)
  backgroundLocationEnabled       Boolean   @default(false)
  microphoneInputEnabled          Boolean   @default(false)
  voiceNotificationsEnabled       Boolean   @default(false)
  cloudSyncEnabled                Boolean   @default(true)
  contactAccessEnabled            Boolean   @default(false)
  emailDraftingEnabled            Boolean   @default(false)
  messageDraftingEnabled          Boolean   @default(false)
  paymentRemindersEnabled         Boolean   @default(false)
  paymentActionsEnabled           Boolean   @default(false)
  calendarIntegrationEnabled      Boolean   @default(false)
  screenshotReceiptScanningEnabled Boolean  @default(false)
  smartSuggestionsEnabled         Boolean   @default(true)
  memoryEnabled                   Boolean   @default(true)
  contactMemoryEnabled            Boolean   @default(false)
  habitLearningEnabled            Boolean   @default(false)
  weatherTriggersEnabled          Boolean   @default(false)
  exchangeRateTriggersEnabled     Boolean   @default(false)
  priceMemoryEnabled              Boolean   @default(false)
  travelContextEnabled            Boolean   @default(false)
  analyticsEnabled                Boolean   @default(false)
  crashReportsEnabled             Boolean   @default(false)
  dataExportEnabled               Boolean   @default(true)
  createdAt                       DateTime  @default(now())
  updatedAt                       DateTime  @updatedAt
  user                            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserVoiceSetting {
  id                        String    @id @default(cuid())
  userId                    String    @unique
  voiceNotificationsEnabled Boolean   @default(false)
  selectedVoiceStyle        String    @default("calm")
  selectedVoiceId           String?
  readFullReminder          Boolean   @default(true)
  readLocationContext       Boolean   @default(true)
  readLiveContext           Boolean   @default(true)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  user                      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ContactMemory {
  id        String     @id @default(cuid())
  userId    String
  name      String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminders Reminder[]

  @@index([userId, name])
}

model ActionPrompt {
  id               String              @id @default(cuid())
  userId           String
  reminderId       String?             @unique
  actionType       ActionType
  title            String
  payload          Json?
  generatedContent String?
  status           ActionPromptStatus  @default(PENDING_CONFIRMATION)
  sensitive        Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  confirmedAt      DateTime?
  completedAt      DateTime?
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  reminder         Reminder?           @relation(fields: [reminderId], references: [id], onDelete: SetNull)
  events           ActionPromptEvent[]

  @@index([userId, status])
}

model ActionPromptEvent {
  id             String                @id @default(cuid())
  userId         String
  actionPromptId String
  eventType      ActionPromptEventType
  metadata       Json?
  createdAt      DateTime              @default(now())
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionPrompt   ActionPrompt          @relation(fields: [actionPromptId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([actionPromptId, createdAt])
}

model IntentParseLog {
  id           String   @id @default(cuid())
  userId       String
  input        String
  parsedOutput Json
  confidence   Float
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Conversation {
  id        String        @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]
  agentRuns AgentRun[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String          @id @default(cuid())
  conversationId String
  userId         String
  role           ChatMessageRole
  content        String
  metadata       Json?
  createdAt      DateTime        @default(now())
  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([userId, createdAt])
}

model AgentRun {
  id             String         @id @default(cuid())
  userId         String
  conversationId String
  status         AgentRunStatus @default(PLANNING)
  userInput      String
  plan           Json
  result         Json?
  errorMessage   String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  completedAt    DateTime?
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolExecutions ToolExecution[]
  approvals      UserApproval[]

  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
}

model ToolExecution {
  id         String              @id @default(cuid())
  userId     String
  agentRunId String
  toolName   String
  input      Json
  output     Json?
  status     ToolExecutionStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentRun   AgentRun            @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId, createdAt])
  @@index([userId, createdAt])
}

model UserApproval {
  id            String               @id @default(cuid())
  userId        String
  agentRunId    String
  itemId        String
  decision      UserApprovalDecision
  editedPayload Json?
  createdAt     DateTime             @default(now())
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentRun      AgentRun             @relation(fields: [agentRunId], references: [id], onDelete: Cascade)

  @@index([agentRunId, createdAt])
  @@index([userId, createdAt])
}
